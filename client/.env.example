# Frontend environment variables
# Copy this file to .env and fill in your actual values

# API URL - Your deployed Render backend URL
# IMPORTANT: For production deployment on Vercel, set this in Vercel Environment Variables
# For local development, use: http://localhost:5000/api
# For production, use: https://your-render-backend.onrender.com/api
# DO NOT use your Vercel frontend URL here
VITE_API_URL=http://localhost:5000/api
