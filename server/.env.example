# Server environment example file
# Copy this file to .env and fill in your actual secrets.

PORT=5000
NODE_ENV=development

# MongoDB connection string
# Use one of these formats depending on your cluster setup.
MONGODB_URI=mongodb://<username>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/<database>?ssl=true&authSource=admin&retryWrites=true&w=majority

# JWT settings
JWT_SECRET=change_this_to_a_secure_secret
JWT_EXPIRE=7d

# Admin user defaults
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@portfolio.dev
ADMIN_PASSWORD=change_this_to_a_secure_password

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL for CORS and callbacks
# Set this to your deployed Vercel frontend URL in production
# Example: https://your-portfolio.vercel.app
FRONTEND_URL=http://localhost:5173
